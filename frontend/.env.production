# Frontend production build settings (Next.js).
#
# IMPORTANT — NEXT_PUBLIC_* variables are inlined at BUILD time, not read at
# runtime.  You MUST set this BEFORE `next build` (or your host's build step),
# not just in the running container.  If you forget, the deployed dashboard
# will silently call http://localhost:8000 and every request fails.
#
# Set this to the public URL of your deployed PyroCore backend (the same value
# you put in the backend's FRONTEND_ORIGIN counterpart).  Use https://.
NEXT_PUBLIC_API_URL=https://pyrocore.fly.dev
