# PyroCore Environment Variables
# Copy to .env and modify values as needed
#
# There are TWO ways to run the server, and they read DIFFERENT variable names:
#
#   1. Container / `uvicorn backend.app:app` (see Dockerfile)
#      -> reads the DATABASE_PATH / STORAGE_ROOT / MIGRATIONS_DIR / HOST / PORT
#         variables below, plus the deployment variables further down.
#
#   2. CLI: `pyrocore start`
#      -> reads pyrocore.toml first, then the PYROCORE_* overrides below, then
#         --host/--port/--db-path flags.  `start` normalises all of these into
#         the canonical DATABASE_PATH / STORAGE_ROOT / MIGRATIONS_DIR values
#         above before launching the server, so both paths serve the SAME
#         database.

# --- Canonical (used by the server / routers) ---
# Database path (container uses /data, local can use ./pyrocore.db)
DATABASE_PATH=/data/pyrocore.db

# Directory for storage files
STORAGE_ROOT=/data/storage_files

# Migrations directory.  The container default (/app/backend/migrations) is set
# in the Dockerfile; locally you can leave this unset (it falls back to the
# bundled backend/migrations).
# MIGRATIONS_DIR=/app/backend/migrations

# Server host and port
HOST=0.0.0.0
PORT=8000

# --- CLI `start` overrides (optional; pyrocore.toml is the primary source) ---
# PYROCORE_DB_PATH=/data/pyrocore.db
# PYROCORE_HOST=0.0.0.0
# PYROCORE_PORT=8000

# --- DEPLOYMENT-ONLY variables (not needed for local dev) ---
# These are what you must set on the host (Render / Fly / Railway) for the app
# to work correctly behind HTTPS with a separately-hosted dashboard.

# CORS: comma-separated list of dashboard origins allowed to call the API.
# WITHOUT THIS the backend only allows http://localhost:3000 and the deployed
# dashboard's requests are blocked by the browser.  Example:
# FRONTEND_ORIGIN=https://pyrocore-dash.vercel.app,https://app.example.com
# FRONTEND_ORIGIN=https://your-frontend.example.com

# Session cookie security.  The dashboard calls the API with
# `credentials: 'include'`.  For a cross-origin HTTPS dashboard the cookie MUST
# be Secure + SameSite=None, otherwise the browser silently drops it and every
# authenticated request 401s.  Leave these unset for local http://localhost dev
# (defaults: insecure + Lax).
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_SAMESITE=none

# Scheduled backup frequency in seconds (default 3600 = 1h).  An immediate
# backup is also taken on every startup.  Lower this (e.g. 300) right after a
# first deploy to confirm the loop is actually running.
# BACKUP_INTERVAL_SECONDS=3600

# --- S3 / object-storage sync (free-tier persistence) ---
# Render's free tier has no persistent disk, so the SQLite DB is wiped on every
# cold start/redeploy.  Point this at an S3 bucket (AWS S3 or any S3-compatible
# store like Cloudflare R2) to use it as the durable home for the DB.  When
# enabled, the latest DB is downloaded on startup and re-uploaded after every
# backup.  Leave S3_SYNC_ENABLED unset/empty to disable (default behaviour).
# S3_SYNC_ENABLED=true
# S3_BUCKET=my-pyrocore-bucket
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=                       # for R2: https://<accountid>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=AKIA...
# S3_SECRET_ACCESS_KEY=...
# S3_PREFIX=pyrocore/                    # trailing slash recommended
