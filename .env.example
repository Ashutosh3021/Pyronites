
# PyroCore Environment Variables
# Copy to .env and modify values as needed

# Database path (container uses /data, local can use ./pyrocore.db)
DATABASE_PATH=/data/pyrocore.db

# Directory for storage files
STORAGE_ROOT=/data/storage_files

# Migrations directory (defaults to bundled)
# MIGRATIONS_DIR=/app/pyrocore/backend/migrations

# Server host and port
HOST=0.0.0.0
PORT=8000
